{
  "compilerOptions": {
    /** 启用增量编译（提升二次构建速度） */
    "incremental": true,
    /** 编译目标（使用最新 ES 规范） */
    "target": "ESNext",
    /** 引入的标准库 */
    "lib": ["ESNext"],

    /** 使用 class 字段标准定义（与现代 JS 行为一致） */
    "useDefineForClassFields": true,
    /** 启用装饰器元数据（NestJS / 依赖注入必需） */
    "emitDecoratorMetadata": true,
    /** 启用实验性装饰器语法 */
    "experimentalDecorators": true,
    /** 项目根目录 */
    "rootDir": ".",
    /** 模块系统（ESM） */
    "module": "ESNext",
    /** 模块解析策略（适配 Vite / bundler） */
    "moduleResolution": "bundler",

    /** 路径别名（与 Vite 保持一致） */
    "paths": {
      "@/*": ["./src/*"],
      "types/*": ["./types/*"],
      "root/*": ["./*"]
    },

    /** 允许导入 JSON 模块 */
    "resolveJsonModule": true,
    /** 禁止直接导入 .ts 扩展名 */
    "allowImportingTsExtensions": false,
    /** 不编译 JavaScript 文件 */
    "allowJs": false,
    /** 启用所有严格类型检查 */
    "strict": true,
    /** 严格空值检查 */
    "strictNullChecks": true,
    /** switch 必须显式处理所有分支 */
    "noFallthroughCasesInSwitch": true,
    /** 禁止隐式 any */
    "noImplicitAny": true,
    /** 强制函数声明返回类型 */
    "noImplicitReturns": true,
    /** 在 this 上进行隐式类型检查 */
    "noImplicitThis": true,
    /** 禁止未使用的局部变量 */
    "noUnusedLocals": true,
    /** 禁止未使用的参数 */
    "noUnusedParameters": true,
    /** 生成对应的`.d.ts`文件 */
    "declaration": false,
    /** 从`.d.ts`文件中排除引用的声明 */
    "declarationMap": false,
    /** 输出目录 */
    "outDir": "out",
    /** 移除输出中的注释 */
    "removeComments": true,
    /** 生成 SourceMap（便于调试） */
    "sourceMap": true,
    /** 允许默认导入（兼容非 ESM 模块） */
    "allowSyntheticDefaultImports": true,
    /** 兼容 CommonJS 与 ESModule */
    "esModuleInterop": true,
    /** 强制文件名使用一致的大小写，避免因操作系统差异导致的问题 */
    "forceConsistentCasingInFileNames": true,
    /** 强制每个文件作为独立模块（适配构建工具） */
    "isolatedModules": true,
    /** 跳过类型检查 */
    "skipLibCheck": true,
    /** 不列出编译过程中处理的所有文件 */
    "listFiles": false
  },
  /** 包含的文件路径模式 */
  "include": ["src/**/*.ts", "types/**/*.d.ts", ".release-it.ts", "vite.config.ts"],
  /** 排除的文件或目录 */
  "exclude": ["node_modules"]
}
