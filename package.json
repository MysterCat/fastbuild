{
  "publisher": "lichenghao",
  "name": "fast-build",
  "displayName": "快速工具",
  "type": "module",
  "version": "0.3.5",
  "packageManager": "pnpm@11.7.0",
  "description": "快速构建的工具",
  "preview": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2815261401/fastbuild.git"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.mjs",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11",
    "vscode": "^1.125.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "fast-build.quick-command",
        "title": "快速执行命令"
      },
      {
        "command": "fast-build.commit",
        "title": "约定式提交",
        "category": "Commitizen",
        "icon": {
          "light": "public/menu-icon-light.svg",
          "dark": "public/menu-icon-dark.svg"
        }
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "fast-build.quick-command",
          "when": "false"
        },
        {
          "command": "fast-build.commit",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "fast-build.quick-command",
          "group": "0_quick_command"
        }
      ],
      "explorer/context": [
        {
          "command": "fast-build.quick-command",
          "group": "0_quick_command"
        }
      ],
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "fast-build.commit",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "快速构建工具",
      "properties": {
        "fast-build.quick-command.config": {
          "type": "object",
          "additionalProperties": "string",
          "default": {},
          "markdownDescription": "右击快速执行命令\n- `$path` 右击的文件(夹)路径\n- `$file` 右击的文件路径，只对文件生效\n- `$dir` 右击的文件夹路径，如果是文件，则会使用文件所在的文件夹路径\n- `$custom` 自定义参数，通过输入框输入参数\n- `$custom<text>` 自定义参数，`text`为默认值\n- `$branch` 分支名称，选择当前仓库的分支名称\n- `$branch<text>` 分支名称，`text`为默认值\n- `$commit` 提交哈希，选择当前仓库的提交哈希"
        },
        "fast-build.quick-command.max-number": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "markdownDescription": "最多存在的终端数量，超过数量将自动关闭。"
        },
        "fast-build.commit.step": {
          "type": "object",
          "default": {
            "default": [
              "type",
              "scope",
              "gitmoji",
              "subject"
            ],
            "Angluar": [
              "type",
              "scope",
              "gitmoji",
              "subject",
              "body",
              "footer"
            ],
            "all": [
              "type",
              "scope",
              "gitmoji",
              "subject",
              "body",
              "breaking",
              "issues"
            ]
          },
          "markdownDescription": "提交消息的步骤，`header`会覆盖`type`,`scope`,`gitmoji`,`subject`,`footer`会覆盖`breaking`,`issues`。",
          "patternProperties": {
            ".*": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "header",
                  "type",
                  "scope",
                  "gitmoji",
                  "subject",
                  "body",
                  "footer",
                  "breaking",
                  "issues"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "fast-build.commit.update.gitmoji": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "是否更新 `gitmoji`。选择该项后，[gitmoji](https://gitmoji.dev/api/gitmojis)将使用连接中的 `gitmoji`描述。"
        },
        "fast-build.commit.scopes": {
          "type": "array",
          "default": [],
          "markdownDescription": "指定 `scope` 中的可选项。"
        },
        "fast-build.commit.push": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "是否推送。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm package",
    "compile": "vp pack",
    "watch": "BUILD_MODE=watch vp pack --watch",
    "package": "BUILD_MODE=package vp pack",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm compile-tests && pnpm compile && pnpm eslint",
    "build": "vsce package",
    "pre-release": "vsce package --pre-release",
    "release": "release-it",
    "lint": "pnpm -r --workspace-root exec vp check",
    "lint:fix": "pnpm -r --workspace-root exec vp check --fix",
    "eslint": "pnpm -r --workspace-root exec eslint .",
    "eslint:fix": "pnpm -r --workspace-root exec eslint . --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "@commitlint/load": "^21.0.2",
    "conventional-changelog-conventionalcommits": "^9.3.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/lint": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "dayjs": "^1.11.21",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.7.0",
    "radashi": "^12.9.1",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.0"
  }
}
